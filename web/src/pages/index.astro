---
import "../styles/global.css";
import TerminalSim from "../components/TerminalSim.astro";

const installCommand = "bun add -g mmx-cli";

const videoFeatures = [
  {
    title: "Batch Conversion",
    desc: "Convert entire directories between formats in a single command. MKV, MP4, AVI, WebM, and more.",
    tech: "ffmpeg · libx264 · libx265",
    wide: true,
  },
  {
    title: "Precise Trimming",
    desc: "Cut media with millisecond accuracy using intuitive start/duration syntax. No video editor needed.",
    tech: "ffmpeg · seek · copy",
    wide: false,
  },
  {
    title: "Format Transcoding",
    desc: "Transcode between any media format while preserving quality. Smart codec selection by default.",
    tech: "ffmpeg · sws · swr",
    wide: true,
  },
];

const imageFeatures = [
  {
    title: "Web Optimization",
    desc: "Lossless compression, resize, and format conversion for web delivery. AVIF, WebP, PNG, JPEG.",
    tech: "mozjpeg · pngquant · libavif",
  },
  {
    title: "Pro Icon Bundling",
    desc: "Generate production-ready .ico and .icns from any source image. Multi-resolution, fully compliant.",
    tech: "libicns · ico · png",
  },
  {
    title: "Format Conversion",
    desc: "Convert between all major image formats with fine-grained control over quality, depth, and metadata.",
    tech: "libpng · libjpeg · libwebp",
  },
];

const flags = [
  { flag: "--tool", aliases: "-t", desc: "Media tool to use (ffmpeg, ffprobe, magick, convert)" },
  { flag: "--action", aliases: "-a", desc: "Action to perform (convert, trim, optimize, info, icon)" },
  { flag: "--input", aliases: "-i", desc: "Input file path, directory, or glob pattern" },
  { flag: "--output", aliases: "-o", desc: "Output path or directory (auto-extension appended)" },
  { flag: "--format", aliases: "-f", desc: "Target format (mp4, webp, avif, ico, icns, etc.)" },
  { flag: "--quality", aliases: "-q", desc: "Quality 0-100 (default: 85). Higher = larger file" },
  { flag: "--width", aliases: "-w", desc: "Output width in pixels (maintains aspect ratio)" },
  { flag: "--no-interactive", aliases: "--batch", desc: "Skip interactive prompts. Use flags only." },
  { flag: "--verbose", aliases: "-v", desc: "Detailed logging for debugging pipeline issues" },
  { flag: "--help", aliases: "-h", desc: "Show full command reference and usage examples" },
];

const perfItems = [
  {
    icon: "bolt",
    title: "Powered by Bun",
    desc: "Instant startup. Native TypeScript. No waiting for a runtime to warm up — your pipeline starts now.",
    stat: "0.01s cold start",
    color: "cyan",
  },
  {
    icon: "shield",
    title: "Zero Bloat",
    desc: "No Electron. No huge dependencies. Just your media tools and a thin, elegant CLI layer that stays out of your way.",
    stat: "&lt;2 MB footprint",
    color: "green",
  },
  {
    icon: "layers",
    title: "Adaptive Rendering",
    desc: "Full Nerd Fonts support with smart fallback. Your terminal renders beautifully, no matter which font you use.",
    stat: "Nerd Fonts ≤ 3.3.0",
    color: "purple",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="mmx — The minimalist media toolkit for your terminal. Blazing fast media processing powered by Bun." />
    <meta name="theme-color" content="#030303" />
    <title>mmx — Media Manipulation eXpress</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="mmx — Media Manipulation eXpress" />
    <meta property="og:description" content="The minimalist media toolkit for your terminal. One command. Zero config. Blazing fast." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-[#030303]">
    <!-- ═══ NAV ═══ -->
    <header class="fixed top-0 left-0 right-0 z-50">
      <nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-display text-sm font-semibold tracking-tight text-zinc-50 hover:text-cyan-400 transition-colors duration-200">
          mmx<span class="text-cyan-500">.</span>
        </a>
        <div class="flex items-center gap-8">
          <a href="#features" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200">Features</a>
          <a href="#flags" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200">Flags</a>
          <a href="#performance" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200">Performance</a>
          <a href="https://github.com/zaidmohd/mmx" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors duration-200">
            GitHub <span class="inline-block ml-0.5 opacity-50">↗</span>
          </a>
        </div>
      </nav>
    </header>

    <main>
      <!-- ════════════════ HERO ════════════════ -->
      <section class="relative min-h-screen flex items-center overflow-hidden">
        <!-- Background layers -->
        <div class="absolute inset-0 bg-subtle bg-grid-sm opacity-20"></div>
        <div class="absolute inset-0 bg-noise bg-repeat bg-[length:128px_128px]"></div>

        <!-- Glow orbs -->
        <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] rounded-full bg-radial-cyan pointer-events-none opacity-80"></div>
        <div class="absolute bottom-[20%] left-[5%] w-[400px] h-[400px] rounded-full bg-radial-green pointer-events-none opacity-60"></div>

        <!-- Content -->
        <div class="relative mx-auto max-w-6xl px-6 pt-28 pb-20 w-full">
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Text side -->
            <div class="space-y-8">
              <!-- Badge -->
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-card text-xs font-mono text-cyan-400 animate-fade-in">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-slow-pulse"></span>
                v0.1.0 — available now
              </div>

              <!-- Gradient heading -->
              <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.05] tracking-tight text-balance animate-slide-up" style="animation-delay: 0.1s;">
                <span class="bg-gradient-to-r from-zinc-50 via-zinc-100 to-zinc-400 bg-clip-text text-transparent">
                  The minimalist
                  <br />
                  media toolkit
                </span>
                <br />
                <span class="bg-gradient-to-r from-cyan-400 via-cyan-300 to-emerald-400 bg-clip-text text-transparent">
                  for your terminal.
                </span>
              </h1>

              <p class="text-lg text-zinc-400 leading-relaxed max-w-lg animate-slide-up" style="animation-delay: 0.2s;">
                One command. Zero configuration. Blazing fast media processing
                powered by Bun, FFmpeg, and ImageMagick.
              </p>

              <!-- Install command row -->
              <div class="flex flex-col sm:flex-row gap-3 items-start animate-slide-up" style="animation-delay: 0.3s;">
                <div class="relative flex-1 w-full sm:w-auto">
                  <div class="flex items-center glass-card rounded-xl overflow-hidden transition-all duration-300 group/cmd hover:border-zinc-700/60 hover:shadow-lg hover:shadow-black/30">
                    <span class="px-3.5 py-3 text-xs font-mono text-emerald-400 shrink-0 border-r border-zinc-800/50">$</span>
                    <code class="flex-1 px-3.5 py-3 text-sm font-mono text-zinc-100 select-all whitespace-nowrap overflow-x-auto tracking-tight">
                      {installCommand}
                    </code>
                    <button
                      class="copy-btn px-3.5 py-3 text-zinc-500 hover:text-cyan-400 transition-colors duration-200 border-l border-zinc-800/50 hover:bg-zinc-800/50 shrink-0"
                      aria-label="Copy install command"
                      data-copy={installCommand}
                    >
                      <svg class="copy-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                      </svg>
                      <svg class="check-icon w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="#22C55E" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </button>
                  </div>
                </div>
                <a
                  href="https://github.com/zaidmohd/mmx"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-zinc-800 text-sm font-medium text-zinc-400 hover:text-zinc-100 hover:border-zinc-700/60 hover:bg-zinc-900/50 transition-all duration-200 whitespace-nowrap"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  View Source
                </a>
              </div>

              <!-- Comment -->
              <p class="text-xs text-zinc-600 font-mono animate-fade-in" style="animation-delay: 0.5s;">
                <span class="text-emerald-500">//</span> No config files. No bloat. Just your files.
              </p>
            </div>

            <!-- Terminal side -->
            <div class="animate-scale-in" style="animation-delay: 0.4s;">
              <TerminalSim />
            </div>
          </div>

          <!-- Scroll hint -->
          <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-zinc-600 animate-fade-in" style="animation-delay: 1.5s;">
            <span class="text-[10px] font-mono tracking-[0.2em] uppercase">Scroll</span>
            <svg class="w-3.5 h-3.5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </div>
        </div>
      </section>

      <!-- ════════════════ FEATURES (BENTO GRID) ════════════════ -->
      <section id="features" class="relative py-32 section-divider">
        <div class="absolute inset-0 bg-noise bg-repeat bg-[length:128px_128px]"></div>

        <div class="relative mx-auto max-w-6xl px-6">
          <!-- Section header -->
          <div class="text-center mb-20 space-y-5">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-card text-xs font-mono text-cyan-400">
              /features
            </span>
            <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-balance">
              <span class="bg-gradient-to-r from-zinc-50 to-zinc-300 bg-clip-text text-transparent">
                Everything you need.
              </span>
              <br />
              <span class="text-zinc-500">Nothing you don't.</span>
            </h2>
            <p class="text-zinc-400 max-w-lg mx-auto text-base">
              Two toolkits. One interface. Same minimal philosophy.
            </p>
          </div>

          <!-- Bento grid: 12-col layout for asymmetry -->
          <div class="grid lg:grid-cols-12 gap-6">
            <!-- ── Left hub: Video & Audio (7 cols) ── -->
            <div class="lg:col-span-7">
              <div class="bento-hub bento-hub-video">
                <!-- Hub header -->
                <div class="hub-header">
                  <div class="w-9 h-9 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-4.5 h-4.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                      <path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-display text-base font-semibold text-zinc-100">Video &amp; Audio</h3>
                    <p class="text-xs text-zinc-500 mt-0.5">Convert, trim, and transcode any media format</p>
                  </div>
                </div>

                <!-- Feature sub-grid: bento arrangement -->
                <div class="grid sm:grid-cols-2 gap-4 mt-6">
                  <!-- Batch Conversion (wide: col-span-2) -->
                  <div class="bento-feature col-span-2" style="--d: 0.1s;">
                    <div class="flex items-start gap-4">
                      <div class="w-7 h-7 mt-0.5 rounded-lg bg-cyan-500/10 flex items-center justify-center shrink-0">
                        <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </div>
                      <div class="space-y-1.5 min-w-0">
                        <h4 class="font-display text-sm font-semibold text-zinc-100">Batch Conversion</h4>
                        <p class="text-sm text-zinc-400 leading-relaxed">{videoFeatures[0].desc}</p>
                        <p class="text-xs font-mono text-zinc-600">{videoFeatures[0].tech}</p>
                      </div>
                    </div>
                  </div>

                  <!-- Precise Trimming -->
                  <div class="bento-feature" style="--d: 0.15s;">
                    <div class="flex items-start gap-4">
                      <div class="w-7 h-7 mt-0.5 rounded-lg bg-cyan-500/10 flex items-center justify-center shrink-0">
                        <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </div>
                      <div class="space-y-1.5 min-w-0">
                        <h4 class="font-display text-sm font-semibold text-zinc-100">Precise Trimming</h4>
                        <p class="text-sm text-zinc-400 leading-relaxed">{videoFeatures[1].desc}</p>
                        <p class="text-xs font-mono text-zinc-600">{videoFeatures[1].tech}</p>
                      </div>
                    </div>
                  </div>

                  <!-- Format Transcoding (wide: col-span-2) -->
                  <div class="bento-feature col-span-2" style="--d: 0.2s;">
                    <div class="flex items-start gap-4">
                      <div class="w-7 h-7 mt-0.5 rounded-lg bg-cyan-500/10 flex items-center justify-center shrink-0">
                        <svg class="w-3.5 h-3.5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </div>
                      <div class="space-y-1.5 min-w-0">
                        <h4 class="font-display text-sm font-semibold text-zinc-100">Format Transcoding</h4>
                        <p class="text-sm text-zinc-400 leading-relaxed">{videoFeatures[2].desc}</p>
                        <p class="text-xs font-mono text-zinc-600">{videoFeatures[2].tech}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ── Right hub: Image Manipulation (5 cols) ── -->
            <div class="lg:col-span-5">
              <div class="bento-hub bento-hub-image">
                <!-- Hub header -->
                <div class="hub-header">
                  <div class="w-9 h-9 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-4.5 h-4.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-display text-base font-semibold text-zinc-100">Image Manipulation</h3>
                    <p class="text-xs text-zinc-500 mt-0.5">Optimize, convert, and bundle for web &amp; desktop</p>
                  </div>
                </div>

                <!-- Feature stack -->
                <div class="space-y-4 mt-6">
                  {imageFeatures.map((f, i) => (
                    <div class="bento-feature" style={`--d: ${0.1 + i * 0.1}s`}>
                      <div class="flex items-start gap-4">
                        <div class="w-7 h-7 mt-0.5 rounded-lg bg-emerald-500/10 flex items-center justify-center shrink-0">
                          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                        </div>
                        <div class="space-y-1.5 min-w-0">
                          <h4 class="font-display text-sm font-semibold text-zinc-100">{f.title}</h4>
                          <p class="text-sm text-zinc-400 leading-relaxed">{f.desc}</p>
                          <p class="text-xs font-mono text-zinc-600">{f.tech}</p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════ FLAGS ════════════════ -->
      <section id="flags" class="relative py-32 section-divider">
        <div class="absolute inset-0 bg-dot-grid opacity-40"></div>

        <div class="relative mx-auto max-w-6xl px-6">
          <div class="text-center mb-20 space-y-5">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-card text-xs font-mono text-cyan-400">
              /flags
            </span>
            <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
              <span class="bg-gradient-to-r from-zinc-50 to-zinc-300 bg-clip-text text-transparent">
                Power-user controls.
              </span>
            </h2>
            <p class="text-zinc-400 max-w-lg mx-auto text-base">
              Bypass the interactive menu. Chain flags for scriptable batch pipelines.
            </p>
          </div>

          <!-- Table -->
          <div class="overflow-hidden rounded-2xl border border-zinc-800/60 bg-zinc-900/30">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-zinc-800/50 bg-zinc-900/50">
                    <th class="text-left px-6 py-4 font-mono text-xs font-semibold text-zinc-500 uppercase tracking-[0.15em]">Flag</th>
                    <th class="text-left px-6 py-4 font-mono text-xs font-semibold text-zinc-500 uppercase tracking-[0.15em] hidden sm:table-cell">Alias</th>
                    <th class="text-left px-6 py-4 font-mono text-xs font-semibold text-zinc-500 uppercase tracking-[0.15em]">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {flags.map((f, i) => (
                    <tr
                      class="flag-row border-b border-zinc-800/30"
                      style={`--d: ${i * 0.04}s`}
                    >
                      <td class="px-6 py-3.5">
                        <code class="font-mono text-sm text-cyan-400">{f.flag}</code>
                      </td>
                      <td class="px-6 py-3.5 hidden sm:table-cell">
                        <code class="font-mono text-xs text-zinc-500">{f.aliases}</code>
                      </td>
                      <td class="px-6 py-3.5 text-zinc-400 text-sm">{f.desc}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- Example snippet -->
          <div class="mt-10 text-center">
            <div class="inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-zinc-900/50 border border-zinc-800/50 font-mono text-sm">
              <span class="text-emerald-400">$</span>
              <code class="text-zinc-400">mmx --tool ffmpeg --action trim --input ./video.mp4 --output ./trimmed</code>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════ PERFORMANCE ════════════════ -->
      <section id="performance" class="relative py-32 section-divider">
        <div class="absolute inset-0 bg-noise bg-repeat bg-[length:128px_128px]"></div>

        <div class="relative mx-auto max-w-6xl px-6">
          <div class="text-center mb-20 space-y-5">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass-card text-xs font-mono text-cyan-400">
              /why-mmx
            </span>
            <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
              <span class="bg-gradient-to-r from-zinc-50 to-zinc-300 bg-clip-text text-transparent">
                Built different.
              </span>
            </h2>
            <p class="text-zinc-400 max-w-lg mx-auto text-base">
              Not another wrapper. A new approach to media tooling.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-5">
            {perfItems.map((item, i) => {
              const colorMap = {
                cyan: { border: "border-cyan-500/20", bg: "bg-cyan-500/10", text: "text-cyan-400" },
                green: { border: "border-emerald-500/20", bg: "bg-emerald-500/10", text: "text-emerald-400" },
                purple: { border: "border-purple-500/20", bg: "bg-purple-500/10", text: "text-purple-400" },
              };
              const c = colorMap[item.color];
              return (
                <div class="perf-card" style={`--d: ${0.1 + i * 0.1}s`}>
                  <div class={`w-10 h-10 rounded-xl ${c.bg} border ${c.border} flex items-center justify-center mb-5`}>
                    <svg class={`w-5 h-5 ${c.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      {item.icon === "bolt" && <path d="M13 10V3L4 14h7v7l9-11h-7z"/>}
                      {item.icon === "shield" && <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>}
                      {item.icon === "layers" && <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>}
                    </svg>
                  </div>
                  <h3 class="font-display text-lg font-semibold text-zinc-100 mb-3">{item.title}</h3>
