{
  "name": "mmx",
  "version": "0.1.0",
  "description": "Media Manipulation eXpress — minimalist CLI media tool powered by Bun, FFmpeg & ImageMagick",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "mmx": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/bun": "latest"
  }
}
